#!/bin/bash
# usage: bin/compile <build-dir> <cache-dir> <env-dir>

set -eo pipefail

# shellcheck disable=SC1090
source "$( readlink -f "$( dirname "${0}" )/../vendor/cmnlib.sh" )"

cmn::main::start "${0}" "${1}" "${2}" "${3}"

# Have rustup install itself in cache directory.
# shellcheck disable=SC2154
RUSTUP_HOME="${cache_dir:?}/rustup"
export RUSTUP_HOME

# Have rustup install cargo in cache directory.
# cargo holds rust tools executables and the downloaded packages.
export CARGO_HOME="${cache_dir:?}/cargo"
export PATH="$CARGO_HOME/bin:$PATH"

cmn::step::start "Installing rust"
pushd "$cache_dir" > /dev/null

if [ ! -x "rustup.sh" ]; then
    cmn::task::start "Downloading rustup (rust official installer)"
    curl https://sh.rustup.rs -sSf > rustup.sh
    chmod u+x rustup.sh
    cmn::task::finish
fi

# Use minimal profile to save disk space.
# This profile provides rust compiler (rustc) and package manager (cargo).
cmn::task::start "Installing rust"
./rustup.sh -y --profile minimal
cmn::task::finish
popd > /dev/null

cmn::step::start "Compile the application"
# `cargo install` builds release binaries and copy them in build_dir/bin directory.
# shellcheck disable=SC2154
cargo install --path "${build_dir:?}" --target-dir "${cache_dir:?}/target" --root "${build_dir:?}"

cmn::main::finish
